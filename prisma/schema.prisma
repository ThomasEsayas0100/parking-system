generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VehicleType {
  BOBTAIL
  TRUCK_TRAILER
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  OVERSTAY
}

enum PaymentType {
  CHECKIN
  MONTHLY_CHECKIN
  EXTENSION
  OVERSTAY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  PARTIALLY_REFUNDED // reserved for future refund API — nothing writes this today
  REFUNDED
  VOIDED   // set by admin cancel (M3); QB-side voids must be synced manually (M2 gap)
  DISPUTED
}

enum AllowListLabel {
  EMPLOYEE
  FAMILY
  VENDOR
  CONTRACTOR
}

enum AuditAction {
  CHECKIN
  CHECKOUT
  EXTEND
  OVERSTAY_START
  OVERSTAY_PAYMENT
  GATE_OPEN
  SPOT_FREED
  REMINDER_SENT
  OVERSTAY_ALERT
  SUSPICIOUS_ENTRY
  GATE_DENIED
  ALLOWLIST_ENTRY
  LAYOUT_SAVED
  LAYOUT_RESTORED
}

model AllowList {
  id        String         @id @default(uuid())
  phone     String         @unique
  name      String
  label     AllowListLabel @default(EMPLOYEE)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
}

model Driver {
  id           String    @id @default(uuid())
  name         String
  email        String?
  phone        String    @unique
  qbCustomerId String?   // QuickBooks customer ID — links to QB customer record
  vehicles     Vehicle[]
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Vehicle {
  id           String      @id @default(uuid())
  driverId     String
  driver       Driver      @relation(fields: [driverId], references: [id])
  unitNumber   String?
  licensePlate String?
  type         VehicleType
  nickname     String?
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([driverId, unitNumber])
  @@unique([driverId, licensePlate])
}

model Spot {
  id         String      @id @default(uuid())
  label      String      @unique
  type       VehicleType
  cx         Float       @default(0)
  cy         Float       @default(0)
  w          Float       @default(0)
  h          Float       @default(0)
  rot        Float       @default(0)
  // Archival, not hard-deletion. Lets historical sessions keep their FK target
  // when a spot is removed from the lot. Live lot queries must filter archivedAt: null.
  archivedAt DateTime?
  sessions   Session[]
  auditLogs  AuditLog[]

  @@index([archivedAt])
}

model Session {
  id                 String        @id @default(uuid())
  spotId             String
  spot               Spot          @relation(fields: [spotId], references: [id])
  driverId           String
  driver             Driver        @relation(fields: [driverId], references: [id])
  vehicleId          String
  vehicle            Vehicle       @relation(fields: [vehicleId], references: [id])
  startedAt          DateTime      @default(now())
  expectedEnd        DateTime
  endedAt            DateTime?
  status             SessionStatus @default(ACTIVE)
  reminderSent       Boolean       @default(false)
  overstayAlertSent  Boolean       @default(false)
  // Terms acceptance (clickwrap consent record). "legacy" = pre-consent-tracking row.
  termsVersion       String        @default("legacy")
  overstayAuthorized Boolean       @default(false)
  // Label of the spot at the moment this session was created. Immutable after
  // creation; displayed everywhere the session's spot is referenced so spot
  // renames or archival do not retroactively rewrite session history.
  // Empty string = legacy row, fallback to spot.label.
  spotLabelSnapshot  String        @default("")
  payments           Payment[]
  auditLogs          AuditLog[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Cron hot path: "find ACTIVE sessions past expectedEnd"
  @@index([status, expectedEnd])
  // Driver session history
  @@index([driverId, status])
}

model Payment {
  id                String        @id @default(uuid())
  sessionId         String
  session           Session       @relation(fields: [sessionId], references: [id])
  type              PaymentType
  externalPaymentId String        // QB invoice/charge ID
  amount            Float
  hours             Float?
  status            PaymentStatus @default(COMPLETED)
  refundedAmount    Float         @default(0)
  refundedAt        DateTime?
  refundExternalId  String?       // QB refund receipt/credit memo ID
  createdAt         DateTime      @default(now())

  // Prevent duplicate payment records from double-poll / double-submit.
  // Free-tier sessions use a UUID so they can't collide.
  @@unique([externalPaymentId])
  // Admin Payments tab + chart
  @@index([createdAt])
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  sessionId String?
  session   Session?    @relation(fields: [sessionId], references: [id])
  driverId  String?
  driver    Driver?     @relation(fields: [driverId], references: [id])
  vehicleId String?
  vehicle   Vehicle?    @relation(fields: [vehicleId], references: [id])
  spotId    String?
  spot      Spot?       @relation(fields: [spotId], references: [id])
  details   String?
  createdAt DateTime    @default(now())

  // Admin Log tab
  @@index([createdAt(sort: Desc)])
  @@index([action, createdAt])
  @@index([driverId, createdAt])
}

model Settings {
  id                    String  @id @default("default")
  hourlyRateBobtail     Float   @default(10.0)
  hourlyRateTruck       Float   @default(15.0)
  monthlyRateBobtail    Float   @default(250.0)
  monthlyRateTruck      Float   @default(400.0)
  overstayRateBobtail   Float   @default(20.0)
  overstayRateTruck     Float   @default(25.0)
  gracePeriodMinutes    Int     @default(15)
  reminderMinutesBefore Int     @default(60)
  totalSpotsBobtail     Int     @default(45)
  totalSpotsTruck       Int     @default(100)
  managerEmail          String  @default("")
  managerPhone          String  @default("")
  bobtailOverflow       Boolean @default(true)
  paymentRequired       Boolean @default(true)
  lotGroups             Json    @default("[]")
  // Clickwrap terms — admin editable, version bumped when text changes
  termsVersion          String  @default("1.0")
  termsBody             String  @default("")
  // QuickBooks OAuth tokens — null when not connected
  qbAccessToken         String?
  qbRefreshToken        String?
  qbRealmId             String?
  qbTokenExpiresAt      DateTime?
}

// Google-Docs-style version history for the lot layout. Each save creates one
// row capturing the full snapshot of spots + groups. Restore is non-destructive —
// restoring an old version appends a new row equal to that state.
model LotLayoutVersion {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  // Admin who saved (email when available, else "admin"; "system" for baseline/backfill).
  createdBy      String
  // Optional commit-style message.
  message        String?
  // Count of non-archived spots in this snapshot (for quick listing).
  spotCount      Int
  // { spots: SpotLayout[], groups: SpotGroup[] }
  snapshot       Json
  // { added: string[], removedArchived: string[], renamed: {id,from,to}[],
  //   moved: string[], typeChanged: string[], groupsChanged: boolean }
  // Null for the initial baseline.
  diffSummary    Json?
  // Previous version id (null only for the baseline).
  parentId       String?
  // Set when this version was created via a restore action.
  restoredFromId String?

  @@index([createdAt(sort: Desc)])
}
