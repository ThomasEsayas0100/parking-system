generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VehicleType {
  BOBTAIL
  TRUCK_TRAILER
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  OVERSTAY
}

enum PaymentType {
  CHECKIN
  MONTHLY_CHECKIN
  EXTENSION
  OVERSTAY
}

enum AuditAction {
  CHECKIN
  CHECKOUT
  EXTEND
  OVERSTAY_START
  OVERSTAY_PAYMENT
  GATE_OPEN
  SPOT_FREED
  REMINDER_SENT
  OVERSTAY_ALERT
  SUSPICIOUS_ENTRY
  GATE_DENIED
  ALLOWLIST_ENTRY
}

model AllowList {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String
  label     String   @default("Employee")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Driver {
  id           String    @id @default(uuid())
  name         String
  email        String
  phone        String    @unique
  qbCustomerId String?   // QuickBooks customer ID — links to QB customer record
  vehicles     Vehicle[]
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Vehicle {
  id           String      @id @default(uuid())
  driverId     String
  driver       Driver      @relation(fields: [driverId], references: [id])
  unitNumber   String?
  licensePlate String?
  type         VehicleType
  nickname     String?
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([driverId, unitNumber])
  @@unique([driverId, licensePlate])
}

model Spot {
  id        String      @id @default(uuid())
  label     String      @unique
  type      VehicleType
  cx        Float       @default(0)
  cy        Float       @default(0)
  w         Float       @default(0)
  h         Float       @default(0)
  rot       Float       @default(0)
  sessions  Session[]
  auditLogs AuditLog[]
}

model Session {
  id                 String        @id @default(uuid())
  spotId             String
  spot               Spot          @relation(fields: [spotId], references: [id])
  driverId           String
  driver             Driver        @relation(fields: [driverId], references: [id])
  vehicleId          String
  vehicle            Vehicle       @relation(fields: [vehicleId], references: [id])
  startedAt          DateTime      @default(now())
  expectedEnd        DateTime
  endedAt            DateTime?
  status             SessionStatus @default(ACTIVE)
  reminderSent       Boolean       @default(false)
  // Terms acceptance (clickwrap consent record)
  termsVersion       String?
  overstayAuthorized Boolean       @default(false)
  payments           Payment[]
  auditLogs          AuditLog[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Payment {
  id                String      @id @default(uuid())
  sessionId         String
  session           Session     @relation(fields: [sessionId], references: [id])
  type              PaymentType
  externalPaymentId String      // QB invoice/charge ID
  amount            Float
  hours             Float?
  status            String      @default("COMPLETED") // PENDING, COMPLETED, REFUNDED, VOIDED, DISPUTED
  refundedAmount    Float       @default(0)
  refundedAt        DateTime?
  refundExternalId  String?     // QB refund receipt/credit memo ID
  createdAt         DateTime    @default(now())
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  sessionId String?
  session   Session?    @relation(fields: [sessionId], references: [id])
  driverId  String?
  driver    Driver?     @relation(fields: [driverId], references: [id])
  vehicleId String?
  vehicle   Vehicle?    @relation(fields: [vehicleId], references: [id])
  spotId    String?
  spot      Spot?       @relation(fields: [spotId], references: [id])
  details   String?
  createdAt DateTime    @default(now())
}

model Settings {
  id                    String  @id @default("default")
  hourlyRateBobtail     Float   @default(10.0)
  hourlyRateTruck       Float   @default(15.0)
  monthlyRateBobtail    Float   @default(250.0)
  monthlyRateTruck      Float   @default(400.0)
  overstayRateBobtail   Float   @default(20.0)
  overstayRateTruck     Float   @default(25.0)
  gracePeriodMinutes    Int     @default(15)
  reminderMinutesBefore Int     @default(60)
  totalSpotsBobtail     Int     @default(45)
  totalSpotsTruck       Int     @default(100)
  managerEmail          String  @default("")
  managerPhone          String  @default("")
  bobtailOverflow       Boolean @default(true)
  paymentRequired       Boolean @default(true)
  lotGroups             Json    @default("[]")
  // Clickwrap terms — admin editable, version bumped when text changes
  termsVersion          String  @default("1.0")
  termsBody             String  @default("")
  // QuickBooks OAuth tokens — stored in DB because they expire/refresh
  qbAccessToken         String  @default("")
  qbRefreshToken        String  @default("")
  qbRealmId             String  @default("")
  qbTokenExpiresAt      DateTime?
}
