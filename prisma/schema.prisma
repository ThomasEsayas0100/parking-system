generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VehicleType {
  BOBTAIL
  TRUCK_TRAILER
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  OVERSTAY
}

enum PaymentType {
  CHECKIN
  MONTHLY_CHECKIN
  MONTHLY_RENEWAL   // Stripe subscription invoice (post-signup cycles)
  EXTENSION
  OVERSTAY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  PARTIALLY_REFUNDED // reserved for future refund API — nothing writes this today
  REFUNDED
  VOIDED   // set by admin cancel (M3); QB-side voids must be synced manually (M2 gap)
  DISPUTED
}

enum AllowListLabel {
  EMPLOYEE
  FAMILY
  VENDOR
  CONTRACTOR
}

enum AuditAction {
  CHECKIN
  CHECKOUT
  EXTEND
  OVERSTAY_START
  OVERSTAY_PAYMENT
  GATE_OPEN
  SPOT_FREED
  REMINDER_SENT
  OVERSTAY_ALERT
  SUSPICIOUS_ENTRY
  GATE_DENIED
  ALLOWLIST_ENTRY
  // Stripe webhook lifecycle + accounting mirror
  STRIPE_WEBHOOK_RECEIVED
  STRIPE_WEBHOOK_REPLAYED   // duplicate event.id hit the idempotency guard
  SALES_RECEIPT_WRITTEN     // QB Sales Receipt created after successful charge
  SALES_RECEIPT_FAILED      // Sales Receipt write errored — admin must reconcile
  REFUND_ISSUED             // Stripe refund initiated by admin
  PAYMENT_DISPUTED          // charge.dispute.created webhook fired
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_CANCELED
}

model AllowList {
  id        String         @id @default(uuid())
  phone     String         @unique
  name      String
  label     AllowListLabel @default(EMPLOYEE)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
}

model Driver {
  id           String    @id @default(uuid())
  name         String
  email        String?
  phone        String    @unique

  // QuickBooks customer — cached lookup for Sales Receipt + Refund Receipt
  // writes. Populated lazily by findOrCreateCustomer() in src/lib/quickbooks.ts
  // the first time we write an accounting entry for this driver.
  qbCustomerId          String?

  // Stripe customer + default payment method. stripeCustomerId is the anchor
  // for card vaulting and subscription billing; populated on first checkout.
  // stripePaymentMethodId is the driver's saved default card (set by
  // payment_method.attached webhook and SetupIntent / Checkout success).
  stripeCustomerId      String? @unique
  stripePaymentMethodId String?

  vehicles     Vehicle[]
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Vehicle {
  id           String      @id @default(uuid())
  driverId     String
  driver       Driver      @relation(fields: [driverId], references: [id])
  unitNumber   String?
  licensePlate String?
  type         VehicleType
  nickname     String?
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([driverId, unitNumber])
  @@unique([driverId, licensePlate])
}

model Spot {
  id        String      @id @default(uuid())
  label     String      @unique
  type      VehicleType
  cx        Float       @default(0)
  cy        Float       @default(0)
  w         Float       @default(0)
  h         Float       @default(0)
  rot       Float       @default(0)
  sessions  Session[]
  auditLogs AuditLog[]
}

model Session {
  id                 String        @id @default(uuid())
  spotId             String
  spot               Spot          @relation(fields: [spotId], references: [id])
  driverId           String
  driver             Driver        @relation(fields: [driverId], references: [id])
  vehicleId          String
  vehicle            Vehicle       @relation(fields: [vehicleId], references: [id])
  startedAt          DateTime      @default(now())
  expectedEnd        DateTime
  endedAt            DateTime?
  status             SessionStatus @default(ACTIVE)
  reminderSent       Boolean       @default(false)
  overstayAlertSent  Boolean       @default(false)
  // Terms acceptance (clickwrap consent record). "legacy" = pre-consent-tracking row.
  termsVersion       String        @default("legacy")
  overstayAuthorized Boolean       @default(false)
  payments           Payment[]
  auditLogs          AuditLog[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Cron hot path: "find ACTIVE sessions past expectedEnd"
  @@index([status, expectedEnd])
  // Driver session history
  @@index([driverId, status])
}

model Payment {
  id        String        @id @default(uuid())
  sessionId String
  session   Session       @relation(fields: [sessionId], references: [id])
  type      PaymentType
  amount    Float
  hours     Float?
  status    PaymentStatus @default(COMPLETED)

  // ─── Stripe identifiers ───────────────────────────────────────────────
  // Populated per event-type. One-time payments set PI + Charge + Checkout
  // Session; subscription renewals set Subscription + Invoice + PI + Charge.
  // All nullable — a row can be written partially on an intermediate webhook
  // and enriched by later events (e.g. PI succeeded → refund arrives).
  stripeCheckoutSessionId String?  // cs_... — resolves redirect after Checkout
  stripePaymentIntentId   String?  @unique  // pi_... — canonical one-time ID
  stripeChargeId          String?           // ch_... — the actual charge record
  stripeSubscriptionId    String?           // sub_... — only for MONTHLY_RENEWAL rows
  stripeInvoiceId         String?           // in_... — subscription invoice that produced this charge
  stripeRefundId          String?           // re_... — set by charge.refunded handler

  refundedAmount Float    @default(0)
  refundedAt     DateTime?

  // Legacy pre-Stripe rows stored QB invoice or charge ID in a generic
  // externalPaymentId column. Preserved here only so admin history still
  // renders; new writes never populate this field.
  legacyQbReference String?

  createdAt DateTime @default(now())

  // Lookup paths — Checkout redirect resolution + charge matching + chart
  @@index([stripeCheckoutSessionId])
  @@index([stripeChargeId])
  @@index([stripeSubscriptionId])
  @@index([createdAt])
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  sessionId String?
  session   Session?    @relation(fields: [sessionId], references: [id])
  driverId  String?
  driver    Driver?     @relation(fields: [driverId], references: [id])
  vehicleId String?
  vehicle   Vehicle?    @relation(fields: [vehicleId], references: [id])
  spotId    String?
  spot      Spot?       @relation(fields: [spotId], references: [id])
  details   String?
  createdAt DateTime    @default(now())

  // Admin Log tab
  @@index([createdAt(sort: Desc)])
  @@index([action, createdAt])
  @@index([driverId, createdAt])
}

model Settings {
  id                    String  @id @default("default")
  hourlyRateBobtail     Float   @default(10.0)
  hourlyRateTruck       Float   @default(15.0)
  monthlyRateBobtail    Float   @default(250.0)
  monthlyRateTruck      Float   @default(400.0)
  overstayRateBobtail   Float   @default(20.0)
  overstayRateTruck     Float   @default(25.0)
  gracePeriodMinutes    Int     @default(15)
  reminderMinutesBefore Int     @default(60)
  totalSpotsBobtail     Int     @default(45)
  totalSpotsTruck       Int     @default(100)
  managerEmail          String  @default("")
  managerPhone          String  @default("")
  bobtailOverflow       Boolean @default(true)
  paymentRequired       Boolean @default(true)
  lotGroups             Json    @default("[]")
  // Clickwrap terms — admin editable, version bumped when text changes
  termsVersion          String  @default("1.0")
  termsBody             String  @default("")
  // QuickBooks OAuth tokens — null when not connected. Used only for
  // writing Sales Receipts / Refund Receipts (accounting output). Payment
  // state is no longer read from QB.
  qbAccessToken         String?
  qbRefreshToken        String?
  qbRealmId             String?
  qbTokenExpiresAt      DateTime?

  // ─── Stripe operational status (displayed on admin dashboard) ────────
  // Stamped by /api/stripe/webhook on every incoming event. Drives the
  // admin "Stripe connection" indicator so dad can see at a glance whether
  // Stripe → our DB is alive.
  lastStripeWebhookAt       DateTime?
  // Stamped by /api/admin/stripe-reconcile after a successful run.
  lastStripeReconcileAt     DateTime?
  // Stripe charge IDs flagged by the last reconcile as missing from our
  // Payment table (or the reverse). Rendered on the admin dashboard as a
  // call to action. Empty array = no divergence.
  stripeReconcileFlaggedIds String[]  @default([])
}

// Webhook idempotency. Every incoming Stripe event is recorded here before
// side effects run. Duplicate event.id deliveries (which Stripe does
// intentionally on retry) short-circuit the handler with STRIPE_WEBHOOK_REPLAYED.
//
// `payload` retains the full event body so we can replay or debug without
// reaching back to Stripe's dashboard.
model StripeEvent {
  id          String   @id      // Stripe event.id (evt_...)
  type        String            // e.g. "payment_intent.succeeded"
  processedAt DateTime @default(now())
  payload     Json

  @@index([type, processedAt])
}
